#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage (from a years/YEAR/dayDD directory):
  aocctl download
  aocctl run
  aocctl submit {1|2}
  aocctl context
EOF
  exit 2
}

repo_root=$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null) || {
  echo "aocctl must be run inside the Advent of Code repository." >&2
  exit 1
}

relative_dir=$(realpath "$PWD" | sed "s#^$(realpath "$repo_root")/##")
if [[ $relative_dir =~ ^years/(20(1[5-9]|2[0-5]))/day(0[1-9]|1[0-9]|2[0-5])(/.*)?$ ]]; then
  year=${BASH_REMATCH[1]}
  day=$((10#${BASH_REMATCH[3]}))
else
  echo "Run aocctl from a year/day folder, for example: years/2025/day01" >&2
  exit 1
fi

[[ $# -ge 1 ]] || usage
command=$1
shift

case $command in
  context)
    [[ $# -eq 0 ]] || usage
    printf 'Advent of Code %s, day %s\n' "$year" "$day"
    ;;
  download)
    [[ $# -eq 0 ]] || usage
    "$repo_root/scripts/download.sh" "$year" "$day"
    ;;
  run)
    [[ $# -eq 0 ]] || usage
    "$repo_root/scripts/run.sh" "$year" "$day"
    ;;
  submit)
    [[ $# -eq 1 ]] || usage
    part=$1
    [[ $part == 1 || $part == 2 ]] || usage
    command -v aoc >/dev/null 2>&1 || {
      echo "aoc not found; see LOCAL_SETUP.md." >&2
      exit 1
    }
    solution_output=$("$repo_root/scripts/run.sh" "$year" "$day")
    printf '%s\n' "$solution_output"
    answer=$(printf '%s\n' "$solution_output" | sed -n "s/^Part $part: //p" | tail -n 1)
    [[ -n $answer ]] || {
      echo "Could not find 'Part $part: ANSWER' in the Python solution output." >&2
      exit 1
    }
    printf 'Submitting year %s, day %s, part %s, answer %s\n' "$year" "$day" "$part" "$answer"
    if submission_output=$(aoc --year "$year" --day "$day" submit "$part" "$answer" 2>&1); then
      printf '%s\n' "$submission_output"
    else
      status=$?
      printf '%s\n' "$submission_output" >&2
      exit "$status"
    fi
    if [[ $part == 1 && $submission_output == *"That's the right answer"* ]]; then
      printf 'Refreshing puzzle for part 2...\n'
      "$repo_root/scripts/download.sh" "$year" "$day"
    fi
    ;;
  *)
    usage
    ;;
esac
